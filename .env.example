# Copie ce fichier en .env pour un test local avec Upstash (sinon repli mémoire).
# Valeurs à récupérer dans Upstash → ta base Redis → onglet "REST API".
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Port (optionnel ; Render le fournit automatiquement)
# PORT=5178
